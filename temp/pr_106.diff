+        </option>
+      </select>
+    </label>
+
+    <label class="debug-row debug-check">
+      <input v-model="showManual" type="checkbox" />
+      <span class="debug-label">隱ｬ譏取嶌繧定｡ｨ遉ｺ縺吶ｋ</span>
+    </label>
+
+    <button class="debug-ok" @click="onOk">OK</button>
+  </div>
+</template>
+
