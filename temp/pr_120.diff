+  it('隍・焚縺ｮ霑ｽ蜉縺ｨ蜑企勁繧呈ｭ｣縺励￥讀懷・縺吶ｋ', () => {
+    const prev = ['a', 'b', 'c', 'd']
+    const next = ['a', 'x', 'c', 'y']
+    const diff = computeLineDiff(prev, next)
+    // b 縺悟炎髯､縲』 縺瑚ｿｽ蜉縲‥ 縺悟炎髯､縲【 縺瑚ｿｽ蜉
+    expect(diff).toEqual([
+      { text: 'a', type: 'unchanged' },
+      { text: 'b', type: 'removed' },
+      { text: 'x', type: 'added' },
+      { text: 'c', type: 'unchanged' },
+      { text: 'd', type: 'removed' },
+      { text: 'y', type: 'added' },
+    ])
+  })
+
+  it('驥崎､・｡後ｒ豁｣縺励￥謇ｱ縺・, () => {
+    const prev = ['a', 'a', 'b']
+    const next = ['a', 'b', 'b']
+    const diff = computeLineDiff(prev, next)
+    // LCS backtracking 縺ｯ譛ｫ蟆ｾ縺九ｉ騾ｲ繧縺溘ａ縲・逡ｪ逶ｮ縺ｮ 'a' 縺ｨ 2逡ｪ逶ｮ縺ｮ 'b' 縺・unchanged 縺ｫ繝槭ャ繝・+    // 1逡ｪ逶ｮ縺ｮ 'a' 縺ｯ removed縲・逡ｪ逶ｮ縺ｮ 'b' 縺ｯ added
+    expect(diff).toEqual([
+      { text: 'a', type: 'removed' },
+      { text: 'a', type: 'unchanged' },
+      { text: 'b', type: 'added' },
+      { text: 'b', type: 'unchanged' },
+    ])
+  })
+
+  it('邨先棡縺ｯ蜈・・鬆・ｺ上〒霑斐＆繧後ｋ', () => {
+    const prev = ['first', 'middle', 'last']
+    const next = ['first', 'new', 'last']
+    const diff = computeLineDiff(prev, next)
+    // unchanged, removed, added, unchanged 縺ｮ鬆・+    expect(diff).toHaveLength(4)
+    expect(diff[0]).toEqual({ text: 'first', type: 'unchanged' })
+    expect(diff[1]).toEqual({ text: 'middle', type: 'removed' })
+    expect(diff[2]).toEqual({ text: 'new', type: 'added' })
+    expect(diff[3]).toEqual({ text: 'last', type: 'unchanged' })
+  })
+
+  it('螟ｧ隕乗ｨ｡縺ｪ蟾ｮ蛻・〒繧よｭ｣縺励￥蜍穂ｽ懊☆繧・, () => {
+    // 100陦後・縲悟､ｧ隕乗ｨ｡縲阪・髢ｾ蛟､縺ｨ縺励※蜊∝・
+    const largeSize = 100
+    const prev = Array.from({ length: largeSize }, (_, i) => `line${i}`)
+    const next = Array.from({ length: largeSize }, (_, i) => `line${i + 1}`)
+    const diff = computeLineDiff(prev, next)
+    // line0 縺悟炎髯､縲〕ine1縲徑ine99 縺・unchanged縲〕ine100 縺瑚ｿｽ蜉 竊・蜷郁ｨ・101 陦・+    expect(diff).toHaveLength(largeSize + 1)
+    expect(diff[0]).toEqual({ text: 'line0', type: 'removed' })
+    expect(diff[diff.length - 1]).toEqual({ text: 'line100', type: 'added' })
+  })
+
+  it('蜈ｨ陦後′逡ｰ縺ｪ繧句ｴ蜷・, () => {
+    const prev = ['a', 'b', 'c']
+    const next = ['x', 'y', 'z']
+    const diff = computeLineDiff(prev, next)
+    // 蜈ｨ陦後′ removed 縺ｾ縺溘・ added
+    const unchanged = diff.filter(d => d.type === 'unchanged')
+    expect(unchanged).toHaveLength(0)
+  })
+})
