+  const choiceButtons = page.locator('[class*="choice"]')
+  const count = await choiceButtons.count()
+  if (count > 0) {
+    await choiceButtons.first().click()
+    await page.waitForTimeout(500)
+    return true
+  }
+  return false
+}
