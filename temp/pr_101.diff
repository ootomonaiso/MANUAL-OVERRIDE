+
+  it('繧ｹ繧ｳ繧｢ 1 縺ｧ 100% 繧定ｿ斐☆', () => {
+    const state: ContradictionState = { pairs: [], score: 1, hasEffect: true }
+    expect(contradictionPercentage(state)).toBe(100)
