+    await page.waitForTimeout(1_000)
+    // 謚墓憧繧ｨ繝ｪ繧｢縺ｧ繧ｯ繝ｪ繝・け・育ｰ｡譏捺兜謫ｲ・・+    await page.mouse.move(400, 300)
+    await page.mouse.down()
+    await page.mouse.move(500, 200)
+    await page.mouse.up()
+
+    // 繧ｨ繝ｳ繝・ぅ繝ｳ繧ｰ縺瑚｡ｨ遉ｺ縺輔ｌ繧九∪縺ｧ蠕・ｩ・+    await page.waitForTimeout(3_000)
+
+    // 繧ｨ繝ｳ繝・ぅ繝ｳ繧ｰ繝代ロ繝ｫ縺ｮ陦ｨ遉ｺ遒ｺ隱・+    const endingCard = page.locator('.ending-card')
+    if (await endingCard.isVisible({ timeout: 5_000 }).catch(() => false)) {
+      // 遏帷崟繝ｬ繝吶Ν繝舌・縺悟ｭ伜惠縺吶ｋ縺薙→繧堤｢ｺ隱・+      const contradictionBar = page.locator('.contradiction-bar')
+      // 陦ｨ遉ｺ縺輔ｌ縺ｦ縺・ｌ縺ｰ濶ｯ縺・ｼ亥ｿ・★陦ｨ遉ｺ縺輔ｌ繧九→縺ｯ髯舌ｉ縺ｪ縺・ｼ・+      const barCount = await contradictionBar.count()
+      expect(barCount).toBeGreaterThanOrEqual(0)
+    }
+
+    expect(errors).toHaveLength(0)
+  })
+
+  test('隍・焚蝗槭・繝励Ξ繧､縺ｧ繧ｲ繝ｼ繝縺後け繝ｩ繝・す繝･縺励↑縺・, async ({ page, errors }) => {
+    // 3蝗樣｣邯壹〒繧ｲ繝ｼ繝繧偵・繝ｬ繧､
+    for (let attempt = 0; attempt < 3; attempt++) {
+      await startGame(page)
+      await bypassTutorial(page)
+
+      // 遏ｭ譎る俣繝励Ξ繧､
+      await page.waitForTimeout(2_000)
+      await page.keyboard.press('Space')
+      await page.waitForTimeout(500)
+
+      // 繧ｮ繝悶い繝・・
+      const giveUpBtn = page.locator('button', { hasText: '繧ｮ繝悶い繝・・' })
+      if (await giveUpBtn.isVisible({ timeout: 1_000 }).catch(() => false)) {
+        await giveUpBtn.click()
+        await page.waitForTimeout(1_000)
+        // 邁｡譏捺兜謫ｲ
+        await page.mouse.move(400, 300)
+        await page.mouse.down()
+        await page.mouse.move(500, 200)
+        await page.mouse.up()
+        await page.waitForTimeout(2_000)
