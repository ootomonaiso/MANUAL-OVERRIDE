+import type { ActionStats, DetectedPlayStyle, PlayStyleResult } from './types'
+
+// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
+// 繝励Ξ繧､繧ｹ繧ｿ繧､繝ｫ讀懷・縺ｮ髢ｾ蛟､
+// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
+
+/** 邨ｱ險磯㍼縺後％縺ｮ蛟､譛ｪ貅縺縺ｨ菫｡鬆ｼ蠎ｦ縺御ｸ九′繧翫∪縺・*/
+const MIN_MEANINGFUL_TICKS = 300
+
+/** 蜷・せ繧ｿ繧､繝ｫ縺ｮ繧ｹ繧ｳ繧｢險育ｮ励〒菴ｿ逕ｨ縺吶ｋ驥阪∩菫よ焚 */
+const WEIGHTS = {
+  /** shotRate 縺ｮ驥阪∩・域判謦・噪蛻､螳夲ｼ・*/
+  shotRate: 3.0,
+  /** jumpRate 縺ｮ驥阪∩・磯亟蠕｡逧・愛螳夲ｼ・*/
+  jumpRate: 2.0,
+  /** moveRate 縺ｮ驥阪∩・域爾邏｢逧・愛螳夲ｼ・*/
+  moveRate: 1.5,
+  /** collisionRate 縺ｮ驥阪∩・域ｷｷ豐悟愛螳夲ｼ・*/
+  collisionRate: 2.5,
+  /** itemsCollected 縺ｮ驥阪∩・域爾邏｢逧・愛螳夲ｼ・*/
+  itemRate: 1.0,
+} as const
+
+/** 蜷・せ繧ｿ繧､繝ｫ縺ｮ蛻､螳壹↓菴ｿ逕ｨ縺吶ｋ譛菴朱明蛟､・・ate = count / ticks * 60・・*/
+const THRESHOLDS = {
+  /** 謾ｻ謦・噪縺ｨ蛻､螳壹☆繧区怙菴主ｰ・茶繝ｬ繝ｼ繝茨ｼ医ヵ繝ｬ繝ｼ繝縺ゅ◆繧翫・蟆・茶謨ｰ・・*/
+  aggressiveShotRate: 0.02,
+  /** 髦ｲ蠕｡逧・→蛻､螳壹☆繧区怙菴弱ず繝｣繝ｳ繝励Ξ繝ｼ繝・*/
+  defensiveJumpRate: 0.015,
+  /** 謗｢邏｢逧・→蛻､螳壹☆繧区怙菴守ｧｻ蜍輔Ξ繝ｼ繝・*/
+  explorerMoveRate: 0.025,
+  /** 豺ｷ豐後→蛻､螳壹☆繧区怙菴手｡晉ｪ√Ξ繝ｼ繝・*/
+  chaoticCollisionRate: 0.005,
+  /** 豸域･ｵ逧・→蛻､螳壹☆繧区怙鬮俶桃菴懊Ξ繝ｼ繝亥粋險・*/
+  passiveMaxTotalRate: 0.01,
+  /** 蝮・｡｡縺ｨ蛻､螳壹☆繧区怙菴弱ヰ繝ｩ繝ｳ繧ｹ豈皮紫・医←縺ｮ謫堺ｽ懊ｂ蜈ｨ菴薙・30%莉･荳具ｼ・*/
+  balancedMinRatio: 0.3,
+} as const
+
+/** 蜷・せ繧ｿ繧､繝ｫ縺ｮ繧ｹ繧ｳ繧｢險育ｮ励〒菴ｿ逕ｨ縺吶ｋ陬懈ｭ｣菫よ焚 */
+const MULTIPLIERS = {
+  /** 繝繝・す繝･縺ｮ髦ｲ蠕｡逧・せ繧ｳ繧｢縺ｸ縺ｮ陬懈ｭ｣菫よ焚 */
+  dashDefensive: 1.5,
+  /** 繧｢繧､繝・Β蜿朱寔縺ｮ謗｢邏｢逧・せ繧ｳ繧｢縺ｸ縺ｮ陬懈ｭ｣菫よ焚 */
+  itemExplorer: 10,
+  /** 蝮・｡｡繧ｹ繧ｳ繧｢縺ｮ蛟咲紫 */
+  balancedRatio: 2,
+  /** 豸域･ｵ逧・せ繧ｳ繧｢縺ｮ蛟咲紫 */
+  passiveRate: 50,
+} as const
+
+/** 繝輔Ξ繝ｼ繝繝ｬ繝ｼ繝茨ｼ・ps・峨Ｕicks 繧堤ｧ呈焚縺ｫ螟画鋤縺吶ｋ縺溘ａ縺ｫ菴ｿ逕ｨ縺吶ｋ */
+const FRAMES_PER_SECOND = 60
+
+/**
+ * ActionStats 縺九ｉ繝励Ξ繧､繧ｹ繧ｿ繧､繝ｫ繧呈耳螳壹☆繧狗ｴ皮ｲ矩未謨ｰ縲・+ *
+ * 蜷・桃菴懊・縲後Ξ繝ｼ繝医搾ｼ・icks 縺ｫ蟇ｾ縺吶ｋ豈皮紫・峨ｒ險育ｮ励＠縲・+ * 髢ｾ蛟､縺ｨ豈碑ｼ・＠縺ｦ譛繧るｫ倥＞繧ｹ繧ｳ繧｢繧呈戟縺､繧ｹ繧ｿ繧､繝ｫ繧定ｿ斐☆縲・+ * ticks 縺悟ｰ代↑縺・ｴ蜷医・ confidence 繧剃ｸ九￡繧九・+ */
+export function detectPlayStyle(stats: ActionStats): PlayStyleResult {
+  const { jumps, moveRight, moveLeft, shots, ticks, collisions, itemsCollected, dashes } = stats
+
+  // ticks 縺・0 縺ｪ繧・passive 繧定ｿ斐☆
+  if (ticks <= 0) {
+    return {
+      style: 'passive',
+      confidence: 0,
+      scores: defaultScores(),
+    }
+  }
+
+  // 繝ｬ繝ｼ繝郁ｨ育ｮ暦ｼ・ormalize: 1遘偵≠縺溘ｊ縺ｮ謫堺ｽ懈焚・・+  const seconds = ticks / FRAMES_PER_SECOND
+  const shotRate = shots / seconds
+  const jumpRate = jumps / seconds
+  const moveRate = (moveRight + moveLeft) / seconds
+  const collisionRate = collisions / seconds
+  const itemRate = itemsCollected / seconds
+  const dashRate = dashes / seconds
+
+  // 蜷・せ繧ｿ繧､繝ｫ縺ｮ繧ｹ繧ｳ繧｢險育ｮ・+  const scores: Record<DetectedPlayStyle, number> = {
+    aggressive: 0,
+    defensive: 0,
+    explorer: 0,
+    balanced: 0,
+    chaotic: 0,
+    passive: 0,
+  }
+
+  // 謾ｻ謦・噪: 蟆・茶縺悟､壹＞
+  if (shotRate >= THRESHOLDS.aggressiveShotRate) {
+    scores.aggressive += WEIGHTS.shotRate * (shotRate / THRESHOLDS.aggressiveShotRate)
+  }
+
+  // 髦ｲ蠕｡逧・ 繧ｸ繝｣繝ｳ繝励・繝繝・す繝･縺悟､壹＞縺悟ｰ・茶縺悟ｰ代↑縺・+  if (jumpRate >= THRESHOLDS.defensiveJumpRate) {
+    scores.defensive += WEIGHTS.jumpRate * (jumpRate / THRESHOLDS.defensiveJumpRate)
+  }
+  if (dashRate > 0) {
+    scores.defensive += dashRate * MULTIPLIERS.dashDefensive
+  }
+
+  // 謗｢邏｢逧・ 遘ｻ蜍輔′螟壹＞
+  if (moveRate >= THRESHOLDS.explorerMoveRate) {
+    scores.explorer += WEIGHTS.moveRate * (moveRate / THRESHOLDS.explorerMoveRate)
+  }
+  if (itemRate > 0) {
+    scores.explorer += WEIGHTS.itemRate * itemRate * MULTIPLIERS.itemExplorer
+  }
+
+  // 豺ｷ豐・ 陦晉ｪ√′螟壹￥縲∵桃菴懊′荳崎ｦ丞援
+  if (collisionRate >= THRESHOLDS.chaoticCollisionRate) {
+    scores.chaotic += WEIGHTS.collisionRate * (collisionRate / THRESHOLDS.chaoticCollisionRate)
+  }
+
+  // 蝮・｡｡: 蜈ｨ謫堺ｽ懊′蝮・ｭ峨↓蛻・淵縺励※縺・ｋ
+  const totalActions = shots + jumps + moveRight + moveLeft + (dashes ?? 0)
+  if (totalActions > 0) {
+    const maxSingle = Math.max(shots, jumps, moveRight + moveLeft, dashes ?? 0)
+    const balanceRatio = 1 - (maxSingle / totalActions)
+    // balancedMinRatio莉･荳奇ｼ医←縺ｮ謫堺ｽ懊ｂ蜈ｨ菴薙・30%莉･荳具ｼ峨↑繧牙插陦｡蛟呵｣・+    if (balanceRatio >= THRESHOLDS.balancedMinRatio) {
+      scores.balanced = balanceRatio * MULTIPLIERS.balancedRatio
+    }
+  }
+
+  // 豸域･ｵ逧・ 謫堺ｽ懃ｷ乗焚縺悟ｰ代↑縺・+  const totalRate = (shots + jumps + moveRight + moveLeft) / seconds
+  if (totalRate < THRESHOLDS.passiveMaxTotalRate) {
+    scores.passive = (THRESHOLDS.passiveMaxTotalRate - totalRate) * MULTIPLIERS.passiveRate
+  }
+
+  // 菫｡鬆ｼ蠎ｦ險育ｮ・+  const confidence = Math.min(1, ticks / MIN_MEANINGFUL_TICKS)
+
+  // 譛鬮倥せ繧ｳ繧｢縺ｮ繧ｹ繧ｿ繧､繝ｫ繧定ｿ斐☆
+  let bestStyle: DetectedPlayStyle = 'balanced'
+  let bestScore = 0
+  for (const [style, score] of Object.entries(scores) as [DetectedPlayStyle, number][]) {
+    if (score > bestScore) {
+      bestScore = score
+      bestStyle = style
+    }
+  }
+
+  return {
+    style: bestStyle,
+    confidence: Math.round(confidence * 100) / 100,
+    scores,
+  }
+}
+
+function defaultScores(): Record<DetectedPlayStyle, number> {
+  return {
+    aggressive: 0,
+    defensive: 0,
+    explorer: 0,
+    balanced: 0,
+    chaotic: 0,
+    passive: 0,
+  }
+}
