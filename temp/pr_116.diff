new file mode 100644
index 0000000..a84044c
--- /dev/null
+++ b/src/domain/contradictionTracker.ts
@@ -0,0 +1,69 @@
+import type { ContradictionState } from './types'
+import type { ChoiceRecord } from './ruleEngine'
+import { CARD_POOL } from '../data/cardPool'
+
+// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
+// 遏帷崟繝医Λ繝・く繝ｳ繧ｰ
+//
+// 繝励Ξ繧､繝､繝ｼ縺御ｺ偵＞縺ｫ遏帷崟縺吶ｋ繧ｫ繝ｼ繝峨ｒ驕ｸ謚槭＠縺溷ｴ蜷医・+// 遏帷崟繧ｹ繧ｳ繧｢繧堤ｴｯ遨阪＠縲・明蛟､繧定ｶ・∴繧九→縲後ご繝ｼ繝縺悟｣翫ｌ縺溘・+// 迚ｹ蛻･縺ｪ邨先忰・・litch・峨∈縺ｮ蛻・ｲ舌ｒ蜿ｯ閭ｽ縺ｫ縺吶ｋ縲・+// 笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏笏
+
+/** 遏帷崟縺・縺､逋ｺ逕溘＠縺溘→縺阪・繧ｹ繧ｳ繧｢蜉邂鈴㍼ */
+const CONTRADICTION_WEIGHT = 0.25
+
+/** glitch 邨先忰縺ｸ縺ｮ蛻・ｲ舌ｒ蜿ｯ閭ｽ縺ｫ縺吶ｋ遏帷崟繧ｹ繧ｳ繧｢縺ｮ髢ｾ蛟､ */
+const GLITCH_THRESHOLD = 0.5
+
+/**
+ * 驕ｸ謚槫ｱ･豁ｴ縺九ｉ遏帷崟迥ｶ諷九ｒ險育ｮ励☆繧狗ｴ皮ｲ矩未謨ｰ縲・+ *
+ * 蜷・き繝ｼ繝峨・ conflictsWith 繝輔ぅ繝ｼ繝ｫ繝峨ｒ蜿ら・縺励・+ * 荳｡譁ｹ縺ｨ繧る∈謚槭＆繧後※縺・ｋ繧ｫ繝ｼ繝峨・繧｢繧呈､懷・縺吶ｋ縲・+ */
+export function trackContradictions(history: ChoiceRecord[]): ContradictionState {
+  const selectedIds = new Set(history.map(r => r.choiceId))
+  const pairs: { idA: string; idB: string }[] = []
+  const seenPairs = new Set<string>()
+
+  for (const record of history) {
+    const card = CARD_POOL.find(c => c.id === record.choiceId)
+    if (!card?.conflictsWith?.length) continue
+
+    for (const conflictId of card.conflictsWith) {
+      if (!selectedIds.has(conflictId)) continue
+
+      // 繝壹い繧剃ｸ諢上↓隴伜挨・磯・ｺ乗裏蜈ｳ・・+      // slice() 縺ｧ繧ｳ繝斐・縺励※縺九ｉ sort() 縺吶ｋ・育ｴ螢顔噪謫堺ｽ懊ｒ驕ｿ縺代ｋ・・+      const pairKey = [record.choiceId, conflictId].slice().sort().join('|')
+      if (seenPairs.has(pairKey)) continue
+      seenPairs.add(pairKey)
+
+      pairs.push({ idA: record.choiceId, idB: conflictId })
+    }
+  }
+
+  // 遏帷崟繧ｹ繧ｳ繧｢險育ｮ暦ｼ域怙螟ｧ 1.0 縺ｫ繧ｯ繝ｩ繝ｳ繝暦ｼ・+  const score = Math.min(1, pairs.length * CONTRADICTION_WEIGHT)
+
+  return {
+    pairs,
+    score,
+    hasEffect: score >= GLITCH_THRESHOLD,
+  }
+}
+
+/**
+ * 遏帷崟繧ｹ繧ｳ繧｢縺・glitch 邨先忰縺ｮ髢ｾ蛟､繧定ｶ・∴縺ｦ縺・ｋ縺句愛螳壹☆繧九・+ */
+export function shouldTriggerGlitchEnd(state: ContradictionState): boolean {
+  return state.hasEffect
+}
+
+/**
+ * 遏帷崟繧ｹ繧ｳ繧｢繧・0縲・00 縺ｮ繝代・繧ｻ繝ｳ繝・・繧ｸ縺ｧ霑斐☆・・I 陦ｨ遉ｺ逕ｨ・峨・+ */
+export function contradictionPercentage(state: ContradictionState): number {
+  return Math.round(state.score * 100)
+}
