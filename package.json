{
  "name": "manual-game",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "preprocess": "node scripts/preprocess.mjs",
    "dev": "node scripts/preprocess.mjs && vite",
    "build": "node scripts/preprocess.mjs && vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "validate": "node scripts/validate-json.mjs",
    "bundle-size": "node scripts/check-bundle-size.mjs",
    "new-genre": "node scripts/new-genre.mjs",
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:e2e": "node tests/test_game.mjs",
    "test:choices": "node tests/test_choices.mjs",
    "test:infinite": "node tests/test_infinite_choices.mjs",
    "test:massive": "node tests/test_massive_choices.mjs",
    "ci": "npm run typecheck && npm run lint && npm run validate && npm run build && npm run bundle-size"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.8"
  }
}
